generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                         Int                        @id @default(autoincrement())
  nombre                     String                     @db.VarChar(100)
  apellido                   String                     @db.VarChar(100)
  email                      String                     @unique @db.VarChar(150)
  password                   String                     @db.VarChar(255)
  telefono                   String?                    @db.VarChar(20)
  rol                        Rol
  activo                     Boolean?                   @default(true)
  fechaRegistro              DateTime?                  @default(now()) @map("fecha_registro") @db.Timestamp(0)
  ultimaSesion               DateTime?                  @map("ultima_sesion") @db.Timestamp(0)
  avisosCreados              Aviso[]                    @relation("AvisoCreador")
  avisosActualizados         Aviso[]                    @relation("AvisoActualizadoPor")
  cursosCreados              Curso[]
  enlacesCreados             EnlaceRecurso[]
  inscripcionesCurso         InscripcionCurso[]
  negocios                   Negocio[]
  pagosConfirmados           PagoInscripcion[]          @relation("pagosConfirmados")
  postulaciones              Postulacion[]
  preguntasCreadas           PreguntaFormulario[]
  programasCreados           Programa[]
  notificaciones             Notificacion[]
  avisosLeidos               AvisoLeido[]
  accesosRecursos            AccesoRecurso[]
  pagosAccesoConfirmados     PagoAccesoRecurso[]        @relation("pagosAccesoConfirmados")
  jovenesJcf                 JovenJcf[]
  campanasCreadas            Campana[]                  @relation("CampanaCreador")
  inversiones                Inversion[]                @relation("InversionInversor")
  inversionesConfirmadas     Inversion[]                @relation("InversionConfirmador")
  actualizacionesCampana     ActualizacionCampana[]     @relation("ActualizacionAutor")
  notasPostulacion           NotaPostulacion[]

  @@index([activo])
  @@index([email])
  @@index([rol])
  @@map("usuarios")
}

model CategoriaNegocio {
  id            Int        @id @default(autoincrement())
  nombre        String     @unique @db.VarChar(100)
  descripcion   String?    @db.Text
  activo        Boolean?   @default(true)
  fechaCreacion DateTime?  @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  negocios      Negocio[]
  programas     Programa[]

  @@index([activo])
  @@map("categorias_negocio")
}

model Negocio {
  id                         Int                        @id @default(autoincrement())
  usuarioId                  Int                        @map("usuario_id")
  nombreNegocio              String                     @map("nombre_negocio") @db.VarChar(200)
  categoriaId                Int                        @map("categoria_id")
  rfc                        String?                    @db.VarChar(13)
  razonSocial                String?                    @map("razon_social") @db.VarChar(200)
  giroComercial              String?                    @map("giro_comercial") @db.VarChar(150)
  direccion                  String?                    @db.Text
  ciudad                     String?                    @db.VarChar(100)
  estado                     String?                    @db.VarChar(100)
  codigoPostal               String?                    @map("codigo_postal") @db.VarChar(10)
  telefonoNegocio            String?                    @map("telefono_negocio") @db.VarChar(20)
  emailNegocio               String?                    @map("email_negocio") @db.VarChar(150)
  numeroEmpleados            Int?                       @default(0) @map("numero_empleados")
  anioFundacion              Int?                       @map("anio_fundacion") @db.SmallInt
  descripcion                String?                    @db.Text
  activo                     Boolean?                   @default(true)
  fechaRegistro              DateTime?                  @default(now()) @map("fecha_registro") @db.Timestamp(0)
  fechaActualizacion         DateTime?                  @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)
  inscripcionesCurso         InscripcionCurso[]
  usuario                    Usuario                    @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  categoria                  CategoriaNegocio           @relation(fields: [categoriaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  postulaciones              Postulacion[]
  jovenesJcf                 JovenJcf[]
  campanas                   Campana[]
  folio                      String?                    @db.VarChar(100)

  @@index([activo])
  @@index([categoriaId])
  @@index([usuarioId, activo])
  @@index([nombreNegocio])
  @@index([usuarioId])
  @@map("negocios")
}

model Programa {
  id                 Int                @id @default(autoincrement())
  nombre             String             @db.VarChar(200)
  descripcion        String?            @db.Text
  tipoPrograma       String?            @map("tipo_programa") @db.VarChar(100)
  categoriaNegocioId Int?               @map("categoria_negocio_id")
  requisitos         String?            @db.Text
  beneficios         String?            @db.Text
  fechaInicio        DateTime?          @map("fecha_inicio") @db.Date
  fechaCierre        DateTime?          @map("fecha_cierre") @db.Date
  montoApoyo         Decimal?           @map("monto_apoyo") @db.Decimal(12, 2)
  activo             Boolean?           @default(true)
  creadoPor          Int                @map("creado_por")
  fechaCreacion      DateTime?          @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  fechaActualizacion DateTime?          @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)
  estado             String?            @db.VarChar(100)
  municipio          String?            @db.VarChar(150)
  postulaciones      Postulacion[]
  categoria          CategoriaNegocio?  @relation(fields: [categoriaNegocioId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creador            Usuario            @relation(fields: [creadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction)
  programasPreguntas ProgramaPregunta[]

  @@index([creadoPor])
  @@index([activo])
  @@index([categoriaNegocioId])
  @@index([fechaInicio, fechaCierre])
  @@index([activo, categoriaNegocioId])
  @@map("programas")
}

model PreguntaFormulario {
  id                 Int                    @id @default(autoincrement())
  pregunta           String                 @db.Text
  tipoRespuesta      TipoRespuesta          @map("tipo_respuesta")
  opcionesRespuesta  Json?                  @map("opciones_respuesta")
  obligatoria        Boolean?               @default(false)
  orden              Int?                   @default(0)
  categoria          String?                @db.VarChar(100)
  placeholder        String?                @db.VarChar(200)
  activa             Boolean?               @default(true)
  creadoPor          Int                    @map("creado_por")
  fechaCreacion      DateTime?              @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  creador            Usuario                @relation(fields: [creadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction)
  programasPreguntas ProgramaPregunta[]
  respuestas         RespuestaPostulacion[]

  @@index([creadoPor])
  @@index([activa])
  @@index([categoria])
  @@index([orden])
  @@map("preguntas_formulario")
}

model ProgramaPregunta {
  id              Int                @id @default(autoincrement())
  programaId      Int                @map("programa_id")
  preguntaId      Int                @map("pregunta_id")
  orden           Int?               @default(0)
  activa          Boolean?           @default(true)
  fechaAsignacion DateTime?          @default(now()) @map("fecha_asignacion") @db.Timestamp(0)
  programa        Programa           @relation(fields: [programaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pregunta        PreguntaFormulario @relation(fields: [preguntaId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([programaId, preguntaId])
  @@index([orden])
  @@index([programaId])
  @@index([preguntaId])
  @@map("programas_preguntas")
}

model Postulacion {
  id                 Int                    @id @default(autoincrement())
  negocioId          Int                    @map("negocio_id")
  programaId         Int                    @map("programa_id")
  usuarioId          Int                    @map("usuario_id")
  estado             EstadoPostulacion?     @default(pendiente)
  fechaPostulacion   DateTime?              @default(now()) @map("fecha_postulacion") @db.Timestamp(0)
  fechaActualizacion DateTime?              @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)
  notasAdmin         String?                @map("notas_admin") @db.Text
  estadoGeo          String?                @map("estado_geo") @db.VarChar(100)
  municipio          String?                @db.VarChar(150)
  negocio            Negocio                @relation(fields: [negocioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  programa           Programa               @relation(fields: [programaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario            Usuario                @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  respuestas         RespuestaPostulacion[]
  trabajadoresJCF    TrabajadorJCF[]
  jovenesJcf         JovenJcf[]
  notas              NotaPostulacion[]

  @@unique([negocioId, programaId])
  @@index([estado])
  @@index([fechaPostulacion])
  @@index([negocioId])
  @@index([estado, fechaPostulacion])
  @@index([programaId])
  @@index([usuarioId])
  @@map("postulaciones")
}

model NotaPostulacion {
  id            Int         @id @default(autoincrement())
  postulacionId Int         @map("postulacion_id")
  usuarioId     Int         @map("usuario_id")
  nota          String      @db.Text
  fechaCreacion DateTime?   @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  postulacion   Postulacion @relation(fields: [postulacionId], references: [id], onDelete: Cascade)
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([postulacionId])
  @@index([usuarioId])
  @@map("notas_postulacion")
}

model RespuestaPostulacion {
  id             Int                @id @default(autoincrement())
  postulacionId  Int                @map("postulacion_id")
  preguntaId     Int                @map("pregunta_id")
  respuesta      String?            @db.Text
  fechaRespuesta DateTime?          @default(now()) @map("fecha_respuesta") @db.Timestamp(0)
  postulacion    Postulacion        @relation(fields: [postulacionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pregunta       PreguntaFormulario @relation(fields: [preguntaId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([postulacionId])
  @@index([preguntaId])
  @@map("respuestas_postulacion")
}

model TrabajadorJCF {
  id             Int         @id @default(autoincrement())
  postulacionId  Int         @map("postulacion_id")
  nombre         String      @db.VarChar(100)
  apellido       String      @db.VarChar(100)
  curp           String?     @unique @db.VarChar(18)
  edad           Int?
  sexo           Sexo?
  telefono       String?     @db.VarChar(20)
  email          String?     @db.VarChar(150)
  nivelEstudios  String?     @map("nivel_estudios") @db.VarChar(100)
  areaFormacion  String?     @map("area_formacion") @db.VarChar(150)
  fechaInicio    DateTime?   @map("fecha_inicio") @db.Date
  fechaFin       DateTime?   @map("fecha_fin") @db.Date
  horasSemanales Int?        @default(30) @map("horas_semanales")
  tutorAsignado  String?     @map("tutor_asignado") @db.VarChar(150)
  activo         Boolean?    @default(true)
  fechaRegistro  DateTime?   @default(now()) @map("fecha_registro") @db.Timestamp(0)
  postulacion    Postulacion @relation(fields: [postulacionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([activo])
  @@index([postulacionId])
  @@map("trabajadores_jcf")
}

model Curso {
  id                 Int                @id @default(autoincrement())
  titulo             String             @db.VarChar(200)
  descripcion        String?            @db.Text
  instructor         String?            @db.VarChar(150)
  duracionHoras      Int?               @map("duracion_horas")
  modalidad          Modalidad?         @default(online)
  fechaInicio        DateTime?          @map("fecha_inicio") @db.Date
  fechaFin           DateTime?          @map("fecha_fin") @db.Date
  cupoMaximo         Int?               @map("cupo_maximo")
  costo              Decimal?           @default(0.00) @db.Decimal(10, 2)
  activo             Boolean?           @default(true)
  creadoPor          Int                @map("creado_por")
  fechaCreacion      DateTime?          @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  fechaActualizacion DateTime?          @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)
  creador            Usuario            @relation(fields: [creadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction)
  inscripciones      InscripcionCurso[]

  @@index([creadoPor])
  @@index([activo])
  @@index([fechaInicio, fechaFin])
  @@map("cursos")
}

model InscripcionCurso {
  id               Int                @id @default(autoincrement())
  cursoId          Int                @map("curso_id")
  usuarioId        Int                @map("usuario_id")
  negocioId        Int?               @map("negocio_id")
  fechaInscripcion DateTime?          @default(now()) @map("fecha_inscripcion") @db.Timestamp(0)
  estado           EstadoInscripcion? @default(inscrito)
  calificacion     Int?
  comentarios      String?            @db.Text
  curso            Curso              @relation(fields: [cursoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario          Usuario            @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  negocio          Negocio?           @relation(fields: [negocioId], references: [id], onUpdate: NoAction)
  pago             PagoInscripcion?

  @@unique([usuarioId, cursoId], name: "unique_usuario_curso")
  @@index([cursoId])
  @@index([estado])
  @@index([usuarioId])
  @@index([negocioId])
  @@map("inscripciones_curso")
}

model Aviso {
  id                    Int           @id @default(autoincrement())
  titulo                String        @db.VarChar(200)
  contenido             String        @db.Text
  tipo                  TipoAviso?    @default(informativo)
  destinatario          Destinatario? @default(clientes)
  linkExterno           String?       @map("link_externo") @db.VarChar(500)
  activo                Boolean?      @default(true)
  fechaPublicacion      DateTime?     @default(now()) @map("fecha_publicacion") @db.Timestamp(0)
  fechaExpiracion       DateTime?     @map("fecha_expiracion") @db.Timestamp(0)
  creadoPor             Int           @map("creado_por")
  actualizadoPor        Int?          @map("actualizado_por")
  creador               Usuario       @relation("AvisoCreador", fields: [creadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction)
  actualizadoPorUsuario Usuario?      @relation("AvisoActualizadoPor", fields: [actualizadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lecturas              AvisoLeido[]

  @@index([creadoPor])
  @@index([actualizadoPor])
  @@index([activo])
  @@index([destinatario])
  @@index([fechaPublicacion])
  @@map("avisos")
}

model EnlaceRecurso {
  id            Int             @id @default(autoincrement())
  titulo        String          @db.VarChar(200)
  descripcion   String?         @db.Text
  url           String          @db.VarChar(500)
  tipo          TipoRecurso?    @default(otro)
  categoria     String?         @db.VarChar(100)
  visiblePara   VisiblePara?    @default(todos) @map("visible_para")
  activo        Boolean?        @default(true)
  costo         Decimal?        @default(0.00) @db.Decimal(10, 2)
  accesos       AccesoRecurso[]
  creadoPor     Int             @map("creado_por")
  fechaCreacion DateTime?       @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  creador       Usuario         @relation(fields: [creadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([creadoPor])
  @@index([activo])
  @@index([categoria])
  @@index([tipo])
  @@map("enlaces_recursos")
}

model ContactoCapyme {
  id                 Int       @id @default(autoincrement())
  telefono           String?   @db.VarChar(20)
  email              String?   @db.VarChar(150)
  direccion          String?   @db.Text
  horarioAtencion    String?   @map("horario_atencion") @db.VarChar(200)
  whatsapp           String?   @db.VarChar(20)
  facebookUrl        String?   @map("facebook_url") @db.VarChar(300)
  instagramUrl       String?   @map("instagram_url") @db.VarChar(300)
  linkedinUrl        String?   @map("linkedin_url") @db.VarChar(300)
  sitioWeb           String?   @map("sitio_web") @db.VarChar(300)
  fechaActualizacion DateTime? @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)

  @@map("contacto_capyme")
}

model PagoInscripcion {
  id                Int              @id @default(autoincrement())
  inscripcionId     Int              @unique @map("inscripcion_id")
  referencia        String           @unique @db.VarChar(30)
  monto             Decimal          @db.Decimal(10, 2)
  tipoPago          TipoPago         @map("tipo_pago")
  estadoPago        EstadoPago       @default(pendiente) @map("estado_pago")
  mercadoPagoId     String?          @unique @map("mercado_pago_id") @db.VarChar(100)
  confirmadoPor     Int?             @map("confirmado_por")
  fechaConfirmacion DateTime?        @map("fecha_confirmacion") @db.Timestamp(0)
  notas             String?          @db.Text
  fechaCreacion     DateTime?        @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  inscripcion       InscripcionCurso @relation(fields: [inscripcionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  confirmador       Usuario?         @relation("pagosConfirmados", fields: [confirmadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([estadoPago])
  @@index([inscripcionId])
  @@index([referencia])
  @@index([confirmadoPor])
  @@index([mercadoPagoId])
  @@map("pagos_inscripcion")
}

model Notificacion {
  id            Int       @id @default(autoincrement())
  usuarioId     Int       @map("usuario_id")
  tipo          String    @db.VarChar(50)
  titulo        String    @db.VarChar(200)
  mensaje       String    @db.Text
  leida         Boolean   @default(false)
  fechaCreacion DateTime? @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId])
  @@index([leida])
  @@map("notificaciones")
}

model AvisoLeido {
  id         Int       @id @default(autoincrement())
  usuarioId  Int       @map("usuario_id")
  avisoId    Int       @map("aviso_id")
  fechaLeido DateTime? @default(now()) @map("fecha_leido") @db.Timestamp(0)
  usuario    Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  aviso      Aviso     @relation(fields: [avisoId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([usuarioId, avisoId], name: "unique_usuario_aviso")
  @@index([usuarioId])
  @@index([avisoId])
  @@map("avisos_leidos")
}

model AccesoRecurso {
  id                 Int                @id @default(autoincrement())
  enlaceId           Int                @map("enlace_id")
  usuarioId          Int                @map("usuario_id")
  estado             EstadoAcceso       @default(pendiente)
  fechaSolicitud     DateTime?          @default(now()) @map("fecha_solicitud") @db.Timestamp(0)
  fechaActualizacion DateTime?          @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)
  enlace             EnlaceRecurso      @relation(fields: [enlaceId], references: [id], onDelete: Cascade)
  usuario            Usuario            @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pago               PagoAccesoRecurso?

  @@unique([usuarioId, enlaceId], name: "unique_usuario_enlace")
  @@index([enlaceId])
  @@index([usuarioId])
  @@index([estado])
  @@map("accesos_recursos")
}

model PagoAccesoRecurso {
  id                Int           @id @default(autoincrement())
  accesoId          Int           @unique @map("acceso_id")
  referencia        String        @unique @db.VarChar(30)
  monto             Decimal       @db.Decimal(10, 2)
  tipoPago          TipoPago      @map("tipo_pago")
  estadoPago        EstadoPago    @default(pendiente) @map("estado_pago")
  mercadoPagoId     String?       @unique @map("mercado_pago_id") @db.VarChar(100)
  confirmadoPor     Int?          @map("confirmado_por")
  fechaConfirmacion DateTime?     @map("fecha_confirmacion") @db.Timestamp(0)
  notas             String?       @db.Text
  fechaCreacion     DateTime?     @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  acceso            AccesoRecurso @relation(fields: [accesoId], references: [id], onDelete: Cascade)
  confirmador       Usuario?      @relation("pagosAccesoConfirmados", fields: [confirmadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([estadoPago])
  @@index([accesoId])
  @@index([referencia])
  @@index([mercadoPagoId])
  @@map("pagos_acceso_recursos")
}

model JovenJcf {
  id                Int          @id @default(autoincrement())
  nombre            String       @db.VarChar(100)
  apellido          String       @db.VarChar(100)
  correo            String?      @db.VarChar(150)
  telefono          String?      @db.VarChar(20)
  curp              String?      @unique @db.VarChar(18)
  negocioId         Int?         @map("negocio_id")
  negocio           Negocio?     @relation(fields: [negocioId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  fechaInicio       DateTime?    @map("fecha_inicio") @db.Date
  fechaTermino      DateTime?    @map("fecha_termino") @db.Date
  urlRecurso        String?      @map("url_recurso") @db.VarChar(500)
  activo            Boolean?     @default(true)
  usuarioId         Int          @map("usuario_id")
  postulacionId     Int?         @map("postulacion_id")
  fechaRegistro     DateTime?    @default(now()) @map("fecha_registro") @db.Timestamp(0)
  usuario           Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  postulacion       Postulacion? @relation(fields: [postulacionId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  estatus           String?      @default("Por registrar") @db.VarChar(50)
  tarjetaEntregada  Boolean?     @default(false) @map("tarjeta_entregada")
  horarios          String?      @db.VarChar(255)
  horarioConfirmado Boolean?     @default(false) @map("horario_confirmado")

  @@index([activo])
  @@index([usuarioId])
  @@index([postulacionId])
  @@index([negocioId])
  @@map("jovenes_jcf")
}

model Campana {
  id                 Int                    @id @default(autoincrement())
  titulo             String                 @db.VarChar(200)
  descripcion        String?                @db.Text
  historia           String?                @db.Text
  metaRecaudacion    Decimal                @map("meta_recaudacion") @db.Decimal(14, 2)
  montoRecaudado     Decimal?               @default(0.00) @map("monto_recaudado") @db.Decimal(14, 2)
  fechaInicio        DateTime?              @map("fecha_inicio") @db.Date
  fechaCierre        DateTime?              @map("fecha_cierre") @db.Date
  estado             EstadoCampana?         @default(en_revision)
  activo             Boolean?               @default(true)
  negocioId          Int                    @map("negocio_id")
  creadoPor          Int                    @map("creado_por")
  fechaCreacion      DateTime?              @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  fechaActualizacion DateTime?              @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)
  negocio            Negocio                @relation(fields: [negocioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  creador            Usuario                @relation("CampanaCreador", fields: [creadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction)
  inversiones        Inversion[]
  tipoCrowdfunding   TipoCrowdfunding       @default(donativo) @map("tipo_crowdfunding")
  interesPct         Decimal?               @map("interes_pct") @db.Decimal(5, 2)
  plazoRetornoDias   Int?                   @map("plazo_retorno_dias")
  imagenUrl          String?                @map("imagen_url") @db.VarChar(500)
  videoUrl           String?                @map("video_url") @db.VarChar(500)
  actualizaciones    ActualizacionCampana[]

  @@index([activo])
  @@index([estado])
  @@index([negocioId])
  @@index([creadoPor])
  @@map("campanas")
}

model Inversion {
  id                 Int        @id @default(autoincrement())
  campanaId          Int        @map("campana_id")
  inversorId         Int        @map("inversor_id")
  monto              Decimal    @db.Decimal(14, 2)
  referencia         String     @unique @db.VarChar(30)
  tipoPago           String     @default("electronico") @map("tipo_pago") @db.VarChar(20)
  estadoPago         EstadoPago @default(pendiente) @map("estado_pago")
  comprobante        String?    @db.VarChar(500)
  notas              String?    @db.Text
  activo             Boolean?   @default(true)
  mercadoPagoId      String?    @unique @map("mercado_pago_id") @db.VarChar(100)
  urlPago            String?    @map("url_pago") @db.VarChar(500)
  fechaPago          DateTime?  @map("fecha_pago") @db.Timestamp(0)
  confirmadoPor      Int?       @map("confirmado_por")
  fechaConfirmacion  DateTime?  @map("fecha_confirmacion") @db.Timestamp(0)
  fechaCreacion      DateTime?  @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  fechaActualizacion DateTime?  @default(now()) @updatedAt @map("fecha_actualizacion") @db.Timestamp(0)
  campana            Campana    @relation(fields: [campanaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inversor           Usuario    @relation("InversionInversor", fields: [inversorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  confirmador        Usuario?   @relation("InversionConfirmador", fields: [confirmadoPor], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([campanaId])
  @@index([inversorId])
  @@index([estadoPago])
  @@index([activo])
  @@index([mercadoPagoId])
  @@map("inversiones")
}

model ActualizacionCampana {
  id            Int      @id @default(autoincrement())
  campanaId     Int      @map("campana_id")
  autorId       Int      @map("autor_id")
  titulo        String   @db.VarChar(200)
  contenido     String   @db.Text
  activo        Boolean  @default(true)
  fechaCreacion DateTime @default(now()) @map("fecha_creacion") @db.Timestamp(0)
  campana       Campana  @relation(fields: [campanaId], references: [id], onDelete: Cascade)
  autor         Usuario  @relation("ActualizacionAutor", fields: [autorId], references: [id], onDelete: NoAction)

  @@index([campanaId])
  @@map("actualizaciones_campana")
}

model CatalogoPdf {
  id          String   @id @default(uuid())
  titulo      String
  descripcion String   @db.Text
  precio      Float
  linkDrive   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

